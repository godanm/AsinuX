{
  "rules": {

    // ── Kazhutha rooms ────────────────────────────────────────────────────────
    "rooms": {
      "$roomId": {
        ".read":  "auth != null && root.child('rooms').child($roomId).child('players').child(auth.uid).exists()",
        ".write": "auth != null && (root.child('rooms').child($roomId).child('players').child(auth.uid).exists() || newData.child('players').child(auth.uid).exists())",
        "players": {
          "$playerId": {
            ".write": "auth != null && auth.uid == $playerId"
          }
        }
      }
    },

    // ── Room code lookup ──────────────────────────────────────────────────────
    "roomCodes": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Player stats & leaderboard ────────────────────────────────────────────
    "stats": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid == $uid || $uid.matches(/^npc_/))"
      }
    },

    // ── Matchmaking ───────────────────────────────────────────────────────────
    "matchmaking": {
      ".read": "auth != null",
      "queue": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid",
          "roomId": {
            ".write": "auth != null"
          }
        }
      },
      "creating": {
        ".write": "auth != null"
      }
    },

    // ── Rummy lobby rooms ─────────────────────────────────────────────────────
    "rummy_rooms": {
      ".read":    "auth != null",
      ".indexOn": ["status"],
      "$roomId": {
        ".write": "auth != null && (root.child('rummy_rooms').child($roomId).child('players').child(auth.uid).exists() || newData.child('players').child(auth.uid).exists())",
        "players": {
          "$playerId": {
            ".write": "auth != null && auth.uid == $playerId"
          }
        }
      }
    },

    // ── Rummy game state (shared, no hand data) ───────────────────────────────
    "rummy_games": {
      "$roomId": {
        ".read":  "auth != null && root.child('rummy_rooms').child($roomId).child('players').child(auth.uid).exists()",
        ".write": "auth != null && root.child('rummy_rooms').child($roomId).child('players').child(auth.uid).exists()"
      }
    },

    // ── Per-player private hands ──────────────────────────────────────────────
    "rummy_hands": {
      "$roomId": {
        "$playerId": {
          ".read":  "auth != null && (auth.uid == $playerId || ($playerId.matches(/^bot_/) && root.child('rummy_rooms').child($roomId).child('hostId').val() == auth.uid))",
          ".write": "auth != null && (auth.uid == $playerId || ($playerId.matches(/^bot_/) && root.child('rummy_rooms').child($roomId).child('hostId').val() == auth.uid))"
        }
      }
    },

    // ── 28 rooms ──────────────────────────────────────────────────────────────
    "game28_rooms": {
      "$roomId": {
        ".read":  "auth != null && root.child('game28_rooms').child($roomId).child('players').child(auth.uid).exists()",
        ".write": "auth != null && (root.child('game28_rooms').child($roomId).child('players').child(auth.uid).exists() || newData.child('players').child(auth.uid).exists())"
      }
    },

    // ── 28 room code lookup ───────────────────────────────────────────────────
    "game28_codes": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },

    // ── Game logs ─────────────────────────────────────────────────────────────
    "gamelogs": {
      "$roomId": {
        ".read":  false,
        ".write": "auth != null",
        "events": {
          // Fix: Allows the cleanup script to filter/sort by timestamp
          ".indexOn": "ts"
        }
      }
    }

  }
}